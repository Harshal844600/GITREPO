int sum =0;
for(int num :nums) sum += num;//calculating  sum

if(sum%2 !=0)return false; //if odd then false 

int target = sum/2;

vector<bool>dp(target+1,false);
dp[0]=true;

for(int num:nums){
    for(int i = target ; i>=nums ; i--){
        dp[i]=dp[i] || dp[i-num];
    }
}
return dp[target]
}
